# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# Runs and experiment outputs (raw data, too large for git)
runs/
passes/*/runs/
passes/*/logs/

# Results (generated analysis, figures — regenerable from runs)
passes/*/results/

# Exceptions: track imported swarms results (small, curated)
!passes/pass_00__swarms__archived/results/
!passes/pass_00__swarms__archived/results/**

# Exceptions: track pass summaries and figures (small, curated)
!passes/pass_01__bp-implementation__archived/results/
!passes/pass_01__bp-implementation__archived/results/**
!passes/pass_02__theory-validation__superseded/results/
!passes/pass_02__theory-validation__superseded/results/**

# External repos
agents-swarms/
autoresearch/data/

# Legacy paths (compatibility symlinks)
configs
workflow/logs/
workflow/artifacts/
workflow/scripts

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
*.swp

# Claude Code project settings
.claude/

# LaTeX build artifacts
*.aux
*.log
*.out
